{
  "name": "project",
  "version": "1.0.0",
  "description": "A mobile-first application for media teams to assign tasks, manage workflows, collaborate on content, and track progress. Designed for editors, writers, designers, producers, and other media roles.",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/middleware/server.ts",
    "build": "tsc",
    "start": "npx prisma migrate deploy && node dist/middleware/server.js",
    "db:migrate": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "postinstall": "prisma generate",
    "migrate": "prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@flydotio/litestream": "^1.0.1",
    "@prisma/client": "^4.15.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "prisma": "^4.15.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "dockerfile": {
    "litestream": true
  }
}
