generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id            String           @id @default(uuid())
  name          String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  users         User[]
  tasks         Task[]
  doorLocations DoorLocation[]
  accessCards   DoorAccessCard[]
  accessLogs    AccessLog[]
  ministryTeams MinistryTeam[]
  devices       Device[]

  permissions TeamPermission?
}

model User {
  id                  String                   @id @default(uuid())
  team                Team                     @relation(fields: [teamId], references: [id])
  teamId              String
  name                String
  email               String                   @unique
  phoneNumber         String?
  profilePhotoUrl     String?
  identityVisibility  String                   @default("NAME")
  passwordHash        String?
  role                String                   @default("DEFAULT")
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  tasks               Task[]                   @relation("AssignedTasks")
  comments            Comment[]
  accessCard          DoorAccessCard?
  additionalRoles     UserAdditionalRole[]
  ministryMemberships UserMinistryMembership[]
  ledMinistryTeams    MinistryTeam[]           @relation("MinistryTeamLeader")
  assignedDevices     Device[]                 @relation("AssignedDevices")
}

model UserAdditionalRole {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String
  createdAt DateTime @default(now())

  @@unique([userId, role])
}

model MinistryTeam {
  id           String                   @id @default(uuid())
  team         Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId       String
  name         String
  code         String
  leader       User?                    @relation("MinistryTeamLeader", fields: [leaderUserId], references: [id])
  leaderUserId String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  members      UserMinistryMembership[]
  devices      Device[]

  @@unique([teamId, code])
}

model UserMinistryMembership {
  id             String       @id @default(uuid())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  ministryTeam   MinistryTeam @relation(fields: [ministryTeamId], references: [id], onDelete: Cascade)
  ministryTeamId String
  isLeader       Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@unique([userId, ministryTeamId])
}

model Device {
  id             String        @id @default(uuid())
  team           Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId         String
  ministryTeam   MinistryTeam? @relation(fields: [ministryTeamId], references: [id], onDelete: SetNull)
  ministryTeamId String?
  name           String
  imageUrl       String?
  category       String
  assignedRole   String?
  assignedUser   User?         @relation("AssignedDevices", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedUserId String?
  status         String        @default("active")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Task {
  id          String       @id @default(uuid())
  team        Team         @relation(fields: [teamId], references: [id])
  teamId      String
  title       String
  description String?
  type        String
  priority    String
  assignee    User?        @relation("AssignedTasks", fields: [assigneeId], references: [id])
  assigneeId  String?
  status      String       @default("assigned")
  dueAt       DateTime?
  serviceDate DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  comments    Comment[]
  attachments Attachment[]
}

model Comment {
  id        String   @id @default(uuid())
  task      Task     @relation(fields: [taskId], references: [id])
  taskId    String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  text      String
  createdAt DateTime @default(now())
}

model Attachment {
  id        String   @id @default(uuid())
  task      Task     @relation(fields: [taskId], references: [id])
  taskId    String
  fileName  String
  url       String
  fileType  String
  createdAt DateTime @default(now())
}

model DoorLocation {
  id          String               @id @default(uuid())
  team        Team                 @relation(fields: [teamId], references: [id])
  teamId      String
  name        String
  description String?
  zone        String               @default("main")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  cardAccess  CardLocationAccess[]
  logs        AccessLog[]
}

model DoorAccessCard {
  id         String               @id @default(uuid())
  team       Team                 @relation(fields: [teamId], references: [id])
  teamId     String
  user       User                 @relation(fields: [userId], references: [id])
  userId     String               @unique
  cardNumber String               @unique
  cardType   String               @default("rfid")
  status     String               @default("active")
  locations  CardLocationAccess[]
  issuedAt   DateTime             @default(now())
  expiresAt  DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  logs       AccessLog[]
}

model CardLocationAccess {
  id         String         @id @default(uuid())
  card       DoorAccessCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId     String
  location   DoorLocation   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId String
  grantedAt  DateTime       @default(now())
  revokedAt  DateTime?

  @@unique([cardId, locationId])
}

model AccessLog {
  id         String         @id @default(uuid())
  team       Team           @relation(fields: [teamId], references: [id])
  teamId     String
  card       DoorAccessCard @relation(fields: [cardId], references: [id])
  cardId     String
  location   DoorLocation   @relation(fields: [locationId], references: [id])
  locationId String
  accessTime DateTime       @default(now())
  status     String         @default("allowed")
  createdAt  DateTime       @default(now())
}

model TeamPermission {
  teamId                  String  @id
  team                    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  adminCanAllocateRoles   Boolean @default(false)
  adminCanAllocateMembers Boolean @default(false)
}
